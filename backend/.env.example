PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://cares:cares@localhost:5432/cares

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=1d
JWT_ISSUER=cares-api
JWT_AUDIENCE=cares-client

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Redis is optional for local development. Set this only when running Redis.
REDIS_URL=
NOTIFICATION_QUEUE_ENABLED=false
NOTIFICATION_QUEUE_REQUIRED=false
DIRECTORY_CACHE_TTL_SECONDS=300

REQUEST_TIMEOUT_MS=15000
METRICS_TOKEN=replace-with-a-random-monitoring-token

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=concern-attachments
